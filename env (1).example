# ============================================================
#  Portfolio Backend — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# MongoDB — local or Atlas connection string
# Local:  mongodb://localhost:27017/portfolio
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio
MONGO_URI=mongodb://localhost:27017/portfolio

# Email notifications (optional — leave blank to disable)
# Use Gmail app password, SendGrid SMTP, Mailtrap, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where to send contact notification emails
NOTIFY_EMAIL=your-personal-email@gmail.com
